# ── API Keys ──
REGION=prc
SILICONFLOW_API_KEY=your_key_here

# Bypass local proxy for SiliconFlow API
NO_PROXY=api.siliconflow.cn,api.siliconflow.com

# ── LangSmith Tracing ──
# LANGSMITH_API_KEY=your_key_here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=AgentTriad

# ── MCP ──
ENABLE_DEEPWIKI=false
# ENABLE_FILESYSTEM_MCP=false

# ── Knowledge Tree ──
ENABLE_KNOWLEDGE_TREE=true
KT_EMBEDDER_TYPE=api
KT_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
KT_EMBEDDING_DIMENSION=1024
# KT_RAG_SIMILARITY_THRESHOLD=0.15  # auto-raised to 0.5 when using semantic embedder

# ── Agent LLM Parameters (optional) ──
# SUPERVISOR_MODEL=anthropic:claude-sonnet-4-20250514
# EXECUTOR_MODEL=anthropic:claude-sonnet-4-20250514
# PLANNER_MODEL=anthropic:claude-sonnet-4-20250514
# SUPERVISOR_MAX_HISTORY_MESSAGES=100
# ENABLE_IMPLICIT_THINKING=true
