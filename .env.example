# AgentTriad 环境变量配置示例
# 复制此文件为 .env 并根据需要修改配置

# =============================================================================
# 基础配置
# =============================================================================

# 区域配置
REGION=prc

# SiliconFlow API 配置
SILICONFLOW_API_KEY=sk-your-key-here

# 绕过本地代理（如 Clash/V2Ray）访问 SiliconFlow API
NO_PROXY=api.siliconflow.cn,api.siliconflow.com

# =============================================================================
# API Keys
# =============================================================================

# Tavily 搜索 API（用于 web_search_tavily 工具）
# 获取地址: https://tavily.com/
TAVILY_API_KEY=tvly-your-key-here

# LangSmith 追踪配置
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agenttriad-local
LANGCHAIN_API_KEY=lsv2-your-key-here

# =============================================================================
# Executor 配置
# =============================================================================

# Executor LLM 采样参数（稳定性优先）
EXECUTOR_TEMPERATURE=0
EXECUTOR_TOP_P=1

# =============================================================================
# 功能开关
# =============================================================================

# 启用 DeepWiki MCP 工具（访问开源项目文档）
ENABLE_DEEPWIKI=false

# 启用文件系统 MCP 工具（工作区只读访问）
# ENABLE_FILESYSTEM_MCP=true
# FILESYSTEM_MCP_ROOT_DIR=workspace/agent

# =============================================================================
# V3+ 异步并发功能
# =============================================================================

# 启用 V3+ 异步并发执行模式
# 当启用时，Executor 在后台执行，支持并发多任务和实时进度查询
# 当禁用时（默认），使用同步执行模式
#
# 使用场景：
# - 启用：长时间运行的任务、需要并发执行多个任务、需要实时进度查询
# - 禁用：简单任务、调试模式、向后兼容
#
# 启用后可用工具：
# - call_executor_async: 非阻塞启动 Executor
# - get_executor_status: 查询任务状态
# - cancel_executor: 取消任务
#
# 默认: false（使用同步执行模式）
ENABLE_V3PLUS_ASYNC=false

# =============================================================================
# 高级配置（通常不需要修改）
# =============================================================================

# Supervisor 推理可见性
# implicit: 推理内容不暴露给用户
# visible: 推理内容拼接到用户侧 content
SUPERVISOR_THINKING_VISIBILITY=implicit

# 隐式推理开关
ENABLE_IMPLICIT_THINKING=true

# LLM 流式输出
ENABLE_LLM_STREAMING=false

# 最大重规划次数
MAX_REPLAN=3

# Executor 最大迭代次数
MAX_EXECUTOR_ITERATIONS=20

# Planner 最大迭代次数
MAX_PLANNER_ITERATIONS=25

# V3 并发执行配置
MAX_PARALLEL_EXECUTORS=4
FANIN_SUMMARY_MAX_CHARS=12000
PLANNER_PARALLEL_REPLAN_MODE=single_replanner

# Observation 治理
MAX_OBSERVATION_CHARS=6500
OBSERVATION_OFFLOAD_THRESHOLD_CHARS=28000
ENABLE_OBSERVATION_OFFLOAD=true
ENABLE_OBSERVATION_SUMMARY=false
OBSERVATION_WORKSPACE_DIR=workspace/.observations

# Executor 反射/检查点（默认 0 关闭）
REFLECTION_INTERVAL=0
CONFIDENCE_THRESHOLD=0.6
